<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_town_view_tree" model="ir.ui.view">
        <field name="name">res.town.view.list</field>
        <field name="model">res.town</field>
        <field name="arch" type="xml">
            <list string="">
                <field name="name" />
                <field name="code" />
                <field name="township_id" />
            </list>
        </field>
    </record>

    <record id="res_town_view_form" model="ir.ui.view">
        <field name="name">res.town.view.form</field>
        <field name="model">res.town</field>
        <field name="arch" type="xml">
            <form string="">
                <sheet>
                    <group>
                        <field name="name" />
                        <field name="code" />
                        <field name="township_id" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    
    <record id="action_res_town" model="ir.actions.act_window">
        <field name="name">Town</field>
        <field name="res_model">res.town</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click "Create" to add a new town.
            </p>
        </field>
    </record>
</odoo>
