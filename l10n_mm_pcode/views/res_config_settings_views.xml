<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.l10n_mm_pcode</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='sms']" position="before">
                <setting string="Use Myanmar Language" help="Display Myanmar address fields in Myanmar language">
                    <field name="use_myanmar_language"/>
                </setting>
            </xpath>
        </field>
    </record>

    <menuitem id="l10n_mm_pcode_menu_configuration"
        name="Settings"
        parent="contacts.res_partner_menu_config"
        sequence="0"
        action="base_setup.action_general_configuration"
        groups="base.group_system"/>
</odoo>
