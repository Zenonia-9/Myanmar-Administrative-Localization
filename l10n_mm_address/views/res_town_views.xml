<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_town_view_tree" model="ir.ui.view">
        <field name="name">res.town.view.list</field>
        <field name="model">res.town</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="township_id"/>
            </list>
        </field>
    </record>

    <record id="res_town_view_search" model="ir.ui.view">
        <field name="name">res.town.view.search</field>
        <field name="model">res.town</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="township_id"/>
                <group expand="0" string="Group By">
                    <filter name="group_township" string="Township" context="{'group_by': 'township_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="res_town_view_form" model="ir.ui.view">
        <field name="name">res.town.view.form</field>
        <field name="model">res.town</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="township_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    
    <record id="action_res_town" model="ir.actions.act_window">
        <field name="name">Towns</field>
        <field name="res_model">res.town</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click "Create" to add a new town.
            </p>
        </field>
    </record>
</odoo>
