<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_district_view_list" model="ir.ui.view">
        <field name="name">res.district.view.list</field>
        <field name="model">res.district</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="state_id"/>
                <field name="district_type"/>
            </list>
        </field>
    </record>

    <record id="res_district_view_search" model="ir.ui.view">
        <field name="name">res.district.view.search</field>
        <field name="model">res.district</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="state_id"/>
                <field name="district_type"/>
                <group expand="0" string="Group By">
                    <filter name="group_state" string="State/Region" context="{'group_by': 'state_id'}"/>
                    <filter name="group_type" string="Type" context="{'group_by': 'district_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="res_district_view_form" model="ir.ui.view">
        <field name="name">res.district.view.form</field>
        <field name="model">res.district</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="state_id"/>
                            <field name="district_type"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_res_district" model="ir.actions.act_window">
        <field name="name">Districts</field>
        <field name="res_model">res.district</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click "Create" to add a new district.
            </p>
        </field>
    </record>
</odoo>
